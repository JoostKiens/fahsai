    "railway:ingest:stations": "node --import=tsx/esm src/scripts/ingest-stations.ts",
    "railway:ingest:weather:today": "node --import=tsx/esm src/scripts/ingest-weather.ts",
    "railway:ingest:weather:today:fallback": "node --import=tsx/esm src/scripts/ingest-weather-today-fallback.ts",
    "railway:ingest:cams:today": "node --import=tsx/esm src/scripts/ingest-cams.ts",
    "railway:ingest:cams:today:fallback": "node --import=tsx/esm src/scripts/ingest-cams-today-fallback.ts",
    "railway:ingest:station-fire-pressure": "node --import=tsx/esm src/scripts/ingest-station-fire-pressure.ts",
    "ingest:station-fire-pressure": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-station-fire-pressure.ts",
