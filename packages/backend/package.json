    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:explain": "node --env-file=.env.local --import=tsx/esm src/scripts/eval/eval-explain.ts",
    "eval:explain:th": "node --env-file=.env.local --import=tsx/esm src/scripts/eval/eval-explain.ts --lang=th",
