    "test:watch": "vitest",
    "ingest:fires": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-fires.ts",
    "ingest:station-readings": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-station-readings.ts",
    "ingest:weather": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-weather.ts",
    "ingest:cams": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-cams.ts",
    "prune": "node --env-file=.env.local --import=tsx/esm src/scripts/prune.ts",
    "ingest:stations": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-stations.ts",
    "ingest:power-plants": "node --env-file=.env.local --import=tsx/esm src/scripts/ingest-power-plants.ts",
    "backfill:station-weather": "node --env-file=.env.local --import=tsx/esm src/scripts/backfill-station-weather.ts",
    "backfill:station-readings": "node --env-file=.env.local --import=tsx/esm src/scripts/backfill-openaq-s3.ts",
    "backfill:fires-noaa21": "node --env-file=.env.local --import=tsx/esm src/scripts/backfill-fires-json.ts",
    "backfill:weather": "node --env-file=.env.local --import=tsx/esm src/scripts/backfill-weather.ts",
    "backfill:station-fire-pressure": "node --env-file=.env.local --import=tsx/esm src/scripts/backfill-station-fire-pressure.ts",
    "backfill:cams-summary": "node --env-file=.env.local --import=tsx/esm src/scripts/backfill-cams-summary.ts",
