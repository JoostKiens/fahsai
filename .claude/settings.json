{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck *)",
      "Bash(pnpm --filter frontend typecheck *)",
      "Bash(pnpm --filter backend typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm --filter frontend lint *)",
      "Bash(pnpm --filter backend lint *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "npm run typecheck --silent" },
          { "type": "command", "command": "npm run lint --silent" }
        ]
      }
    ]
  }
}
